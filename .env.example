# Copy to .env and fill in your values. Never commit .env.

# Databricks CLI profile (from ~/.databrickscfg)
DATABRICKS_PROFILE=DEFAULT

# SQL warehouse to run UC function calls through (required)
DATABRICKS_WAREHOUSE_ID=

# Unity Catalog target — defaults match the dev target in databricks.yml
BDD_CATALOG=dev
BDD_SCHEMA=compliance_yourname
